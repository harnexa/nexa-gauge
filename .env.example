# nexa-gauge environment template
# Copy to .env and set the values you need.

# Runtime
ENV=development
LOG_LEVEL=INFO

# LLM defaults
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local embedding model used by similarity/dedup components
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Evidence and execution controls
EVIDENCE_THRESHOLD=0.75
BUDGET_CAP_USD=
HF_TOKEN=

# Optional per-node model overrides
# Pattern:
#   LLM_{NODE}_MODEL=<model>
#   LLM_{NODE}_FALLBACK_MODEL=<model>
#   LLM_{NODE}_TEMPERATURE=<float>
#
# Supported node names:
#   chunk, claims, dedup, relevance, grounding,
#   redteam, geval_steps, geval, reference
#
# Example:
# LLM_CLAIMS_MODEL=openai/gpt-4o-mini
# LLM_CLAIMS_FALLBACK_MODEL=openai/gpt-4o
# LLM_GROUNDING_TEMPERATURE=0.0
