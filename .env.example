# Required environment variables for lumis-eval
# Copy to .env and fill in values.

ENV=development                   # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ── Default judge LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=openai               # openai | anthropic | groq | etc. (LiteLLM provider)
LLM_MODEL=gpt-4o-mini             # Default LiteLLM model string for all nodes
OPENAI_API_KEY=                   # Required if LLM_PROVIDER=openai
ANTHROPIC_API_KEY=                # Required if LLM_PROVIDER=anthropic

# ── Per-node model overrides (all optional) ────────────────────────────────
# Override the primary model for a specific node:
#   LLM_{NODE}_MODEL=<litellm-model-string>
# Override the fallback model (used if primary call fails):
#   LLM_{NODE}_FALLBACK_MODEL=<litellm-model-string>
# Override temperature (default 0.0):
#   LLM_{NODE}_TEMPERATURE=<float>
#
# Available node names and their env var prefixes:
#   claims            → LLM_CLAIMS_*          (legacy: LLM_CLAIM_EXTRACTOR_*)
#   grounding         → LLM_GROUNDING_*       (legacy: LLM_HALLUCINATION_*)
#   relevance         → LLM_RELEVANCE_*       (legacy: LLM_RAGAS_*)
#   redteam           → LLM_REDTEAM_*         (legacy: LLM_ADVERSARIAL_*)
#   rubric            → LLM_RUBRIC_*          (legacy: LLM_RUBRIC_EVAL_*)
#   faithfulness      → LLM_FAITHFULNESS_*
#   answer_relevancy  → LLM_ANSWER_RELEVANCY_*
#
# Examples:
# LLM_CLAIMS_MODEL=gpt-4o
# LLM_CLAIMS_FALLBACK_MODEL=gpt-4o-mini
# LLM_GROUNDING_MODEL=gpt-4o-mini
# LLM_GROUNDING_FALLBACK_MODEL=gpt-3.5-turbo

# ── Web search (optional) ──────────────────────────────────────────────────
TAVILY_API_KEY=                   # Required if WEB_SEARCH_ENABLED=true
WEB_SEARCH_ENABLED=false          # true | false

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2  # sentence-transformers model name (local, no API key)

# ── Vector storage ─────────────────────────────────────────────────────────
LANCEDB_PATH=./.lancedb           # Local LanceDB directory path
LANCEDB_MCP_URI=                  # Optional: MCP LanceDB connection URI

# ── Evidence routing ───────────────────────────────────────────────────────
EVIDENCE_THRESHOLD=0.75           # Retrieval similarity threshold (0.0–1.0)

# ── Job execution ──────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=4             # TaskIQ worker concurrency
BUDGET_CAP_USD=1                  # Optional: reject jobs exceeding this USD estimate

# ── Composite score weights (must sum to 1.0) ──────────────────────────────
SCORE_WEIGHT_FAITHFULNESS=0.4
SCORE_WEIGHT_HALLUCINATION=0.3
SCORE_WEIGHT_RUBRIC=0.2
SCORE_WEIGHT_SAFETY=0.1

# ── Observability (optional) ───────────────────────────────────────────────
# Install the optional extra to enable: uv pip install "lumiseval-graph[observability]"
# When LANGFUSE_SECRET_KEY is set:
#   - Every LiteLLM call is forwarded to Langfuse automatically (cost + latency)
#   - Each pipeline node is traced as a Langfuse span
#   - The overall run_graph() call is the top-level trace with composite_score
LANGFUSE_SECRET_KEY=          # sk-lf-...
LANGFUSE_PUBLIC_KEY=          # pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com  # or your self-hosted URL
