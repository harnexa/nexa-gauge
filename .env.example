# Required environment variables for lumis-eval
# Copy to .env and fill in values.

ENV=development                   # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# LLM / Judge
LLM_PROVIDER=openai               # openai | anthropic | groq | etc. (LiteLLM provider)
LLM_MODEL=gpt-4o-mini             # LiteLLM model string
OPENAI_API_KEY=                   # Required if LLM_PROVIDER=openai
ANTHROPIC_API_KEY=                # Required if LLM_PROVIDER=anthropic

# Web search (optional)
TAVILY_API_KEY=                   # Required if WEB_SEARCH_ENABLED=true
WEB_SEARCH_ENABLED=false          # true | false

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2  # sentence-transformers model name (local, no API key)

# Vector storage
LANCEDB_PATH=./.lancedb           # Local LanceDB directory path
LANCEDB_MCP_URI=                  # Optional: MCP LanceDB connection URI

# Evidence routing
EVIDENCE_THRESHOLD=0.75           # Retrieval similarity threshold (0.0–1.0)

# Job execution
MAX_CONCURRENT_JOBS=4             # TaskIQ worker concurrency
BUDGET_CAP_USD=                   # Optional: reject jobs exceeding this USD estimate

# Composite score weights (must sum to 1.0)
SCORE_WEIGHT_FAITHFULNESS=0.4
SCORE_WEIGHT_HALLUCINATION=0.3
SCORE_WEIGHT_RUBRIC=0.2
SCORE_WEIGHT_SAFETY=0.1
